<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_single_bg"
    android:padding="14dp">

    <!-- Date header -->
    <TextView
        android:id="@+id/tv_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jul 04"
        android:textSize="16sp"
        android:textColor="#6B8E6B"
        android:fontFamily="sans-serif-medium" />

    <!-- Dhikr rows -->
    <LinearLayout
        android:id="@+id/row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/tv_dhikr_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SubhanAllah"
            android:textSize="14sp"
            android:textColor="#2D3436"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_count_1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="33"
            android:textSize="14sp"
            android:textColor="#6B8E6B"
            android:fontFamily="sans-serif-bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tv_dhikr_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Alhamdulillah"
            android:textSize="14sp"
            android:textColor="#2D3436"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_count_2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="33"
            android:textSize="14sp"
            android:textColor="#6B8E6B"
            android:fontFamily="sans-serif-bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/tv_dhikr_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Allahu Akbar"
            android:textSize="14sp"
            android:textColor="#2D3436"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_count_3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="33"
            android:textSize="14sp"
            android:textColor="#6B8E6B"
            android:fontFamily="sans-serif-bold" />

    </LinearLayout>

    <!-- More indicator -->
    <TextView
        android:id="@+id/tv_more"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+2 more"
        android:textSize="10sp"
        android:textColor="#888888"
        android:layout_marginTop="4dp"
        android:visibility="gone" />

</LinearLayout>